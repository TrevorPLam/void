        require(recipients.length == amounts.length);
        
        for (uint i = 0; i < recipients.length; i++) {
            // BAD: No overflow check
            balances[recipients[i]] += amounts[i];
            totalSupply += amounts[i];
        }
    }

    // BAD: No input validation
