// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract SecureToken is ERC20, AccessControl, ReentrancyGuard, Pausable {
    using SafeMath for uint256;

    // Roles
    bytes32 public constant MINTER_ROLE = keccak256("MINTER_ROLE");
    bytes32 public constant PAUSER_ROLE = keccak256("PAUSER_ROLE");
    bytes32 public constant ADMIN_ROLE = keccak256("ADMIN_ROLE");

    // State variables
    mapping(address => uint256) private _balances;
    mapping(address => mapping(address => uint256)) private _allowances;
    uint256 private _totalSupply;
    
    // Security variables
    uint256 private _maxTransferAmount;
    uint256 private _transferCooldown;
    mapping(address => uint256) private _lastTransferTime;

    // Events
    event TokensMinted(address indexed to, uint256 amount);
    event TokensBurned(address indexed from, uint256 amount);
    event MaxTransferUpdated(uint256 newMaxAmount);
    event TransferCooldownUpdated(uint256 newCooldown);

    constructor(
        string memory name,
        string memory symbol,
        uint256 initialSupply,
        uint256 maxTransferAmount,
        uint256 transferCooldown
    ) ERC20(name, symbol) {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(MINTER_ROLE, msg.sender);
        _grantRole(PAUSER_ROLE, msg.sender);
        _grantRole(ADMIN_ROLE, msg.sender);
        
        _maxTransferAmount = maxTransferAmount;
        _transferCooldown = transferCooldown;
        
        if (initialSupply > 0) {
            _mint(msg.sender, initialSupply);
        }
    }

    // Mint function with access control
    function mint(address to, uint256 amount) 
        public 
        onlyRole(MINTER_ROLE) 
        nonReentrant 
        whenNotPaused 
    {
        require(to != address(0), "SecureToken: Cannot mint to zero address");
        require(amount > 0, "SecureToken: Amount must be greater than zero");
        
        // Check for potential overflow
        require(_totalSupply.add(amount) <= type(uint256).max, "SecureToken: Overflow detected");
        
        _mint(to, amount);
        emit TokensMinted(to, amount);
    }

    // Burn function
    function burn(uint256 amount) 
        public 
        nonReentrant 
        whenNotPaused 
    {
        require(amount > 0, "SecureToken: Amount must be greater than zero");
        require(_balances[msg.sender] >= amount, "SecureToken: Insufficient balance");
        
        _burn(msg.sender, amount);
        emit TokensBurned(msg.sender, amount);
    }

    // Transfer function with security checks
    function transfer(address to, uint256 amount) 
        public 
        override 
        nonReentrant 
        whenNotPaused 
        returns (bool) 
    {
        return _executeTransfer(msg.sender, to, amount);
    }

    // TransferFrom function with security checks
    function transferFrom(address from, address to, uint256 amount) 
        public 
        override 
        nonReentrant 
        whenNotPaused 
        returns (bool) 
    {
        uint256 currentAllowance = allowance(from, msg.sender);
        require(currentAllowance >= amount, "SecureToken: Insufficient allowance");
        
        bool success = _executeTransfer(from, to, amount);
        if (success) {
            _approve(from, msg.sender, currentAllowance.sub(amount));
        }
        return success;
    }

    // Internal transfer function with security validations
    function _executeTransfer(address from, address to, uint256 amount) 
        internal 
        returns (bool) 
    {
        // Basic validations
        require(to != address(0), "SecureToken: Cannot transfer to zero address");
        require(_balances[from] >= amount, "SecureToken: Insufficient balance");
        require(amount <= _maxTransferAmount, "SecureToken: Transfer amount exceeds maximum");
        
        // Transfer cooldown check
        if (_transferCooldown > 0) {
            require(
                block.timestamp >= _lastTransferTime[from].add(_transferCooldown),
                "SecureToken: Transfer cooldown not met"
            );
            _lastTransferTime[from] = block.timestamp;
        }

        // Perform transfer
        _balances[from] = _balances[from].sub(amount);
        _balances[to] = _balances[to].add(amount);

        emit Transfer(from, to, amount);
        return true;
    }

    // Approve function with reentrancy protection
    function approve(address spender, uint256 amount) 
        public 
        override 
        nonReentrant 
        returns (bool) 
    {
        require(spender != address(0), "SecureToken: Cannot approve zero address");
        
        _approve(msg.sender, spender, amount);
        return true;
    }

    // Internal approve function
    function _approve(address owner, address spender, uint256 amount) internal {
        require(owner != address(0), "SecureToken: Owner cannot be zero address");
        require(spender != address(0), "SecureToken: Spender cannot be zero address");
        
        _allowances[owner][spender] = amount;
        emit Approval(owner, spender, amount);
    }

    // Emergency functions
    function pause() public onlyRole(PAUSER_ROLE) {
        _pause();
    }

    function unpause() public onlyRole(PAUSER_ROLE) {
        _unpause();
    }

    // Admin functions
    function setMaxTransferAmount(uint256 newMaxAmount) 
        public 
        onlyRole(ADMIN_ROLE) 
    {
        require(newMaxAmount > 0, "SecureToken: Max amount must be greater than zero");
        _maxTransferAmount = newMaxAmount;
        emit MaxTransferUpdated(newMaxAmount);
    }

    function setTransferCooldown(uint256 newCooldown) 
        public 
        onlyRole(ADMIN_ROLE) 
    {
        _transferCooldown = newCooldown;
        emit TransferCooldownUpdated(newCooldown);
    }

    // View functions
    function maxTransferAmount() external view returns (uint256) {
        return _maxTransferAmount;
    }

    function transferCooldown() external view returns (uint256) {
        return _transferCooldown;
    }

    function lastTransferTime(address user) external view returns (uint256) {
        return _lastTransferTime[user];
    }

    // Required overrides
    function _beforeTokenTransfer(
        address from,
        address to,
        uint256 amount
    ) internal override whenNotPaused {
        super._beforeTokenTransfer(from, to, amount);
    }
}
```
